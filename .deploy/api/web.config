<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <location path="." inheritInChildApplications="false">
    <system.webServer>
      <modules>
        <remove name="WebDAVModule" />
      </modules>
      <handlers>
        <remove name="WebDAV" />
        <add name="aspNetCore" path="*" verb="*" modules="AspNetCoreModuleV2" resourceType="Unspecified" />
      </handlers>
      <aspNetCore processPath="dotnet"
                  arguments=".\MADai.Api.dll"
                  stdoutLogEnabled="false"
                  stdoutLogFile=".\logs\stdout"
                  hostingModel="inprocess">
        <environmentVariables>
          <environmentVariable name="ASPNETCORE_ENVIRONMENT" value="Production" />
          <environmentVariable name="COMPLUS_ForceENC" value="0" />
          <environmentVariable name="ConnectionStrings__Default" value="Server=WINSVRSQL03.hostserv.co.za,1433;Database=madai;User Id=madproducts;Password=P@szw0rd;TrustServerCertificate=True;" />
          <environmentVariable name="ConnectionStrings__Hangfire" value="Server=WINSVRSQL03.hostserv.co.za,1433;Database=madaihangfire;User Id=madproducts;Password=P@szw0rd;TrustServerCertificate=True;" />
          <environmentVariable name="Jwt__Secret" value="-rJpyqvrX^@[bC}fcG54CmuVJ?r%(c}!.9o;mFEG=r&lt;1ueN7-E;h+XO(%T+*adY7" />
          <environmentVariable name="Cors__Origins__0" value="https://madai.madprospects.com" />
          <environmentVariable name="CLAUDE_WORKER_TOKEN" value="2ad756e27971bea3771e47b4370ad157e7d9e4d71e005fa67061ef5086449fea" />
          <environmentVariable name="SMTP_HOST" value="smtp.dreamhost.com" />
          <environmentVariable name="SMTP_PORT" value="465" />
          <environmentVariable name="SMTP_SECURE" value="true" />
          <environmentVariable name="SMTP_USER" value="admin@madleads.ai" />
          <environmentVariable name="SMTP_PASS" value="P@szw0rdML" />
          <environmentVariable name="SMTP_FROM_ADDRESS" value="admin@madleads.ai" />
        </environmentVariables>
      </aspNetCore>
      <httpProtocol>
        <customHeaders>
          <add name="X-Content-Type-Options" value="nosniff" />
          <add name="X-Frame-Options" value="DENY" />
          <add name="Referrer-Policy" value="strict-origin-when-cross-origin" />
        </customHeaders>
      </httpProtocol>
      <security>
        <requestFiltering>
          <verbs allowUnlisted="true">
            <add verb="PATCH" allowed="true" />
            <add verb="PUT" allowed="true" />
            <add verb="DELETE" allowed="true" />
            <add verb="OPTIONS" allowed="true" />
          </verbs>
          <requestLimits maxAllowedContentLength="209715200" />
        </requestFiltering>
      </security>
      <rewrite>
        <rules>
          <rule name="WebSocketPassthrough" stopProcessing="true">
            <match url="^hubs/(.*)" />
            <action type="None" />
          </rule>
        </rules>
      </rewrite>
    </system.webServer>
  </location>
</configuration>




