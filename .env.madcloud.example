# MADCloud AI service provider integration
MADCLOUD_API_URL=https://madcloudapi.madprospects.com
MADCLOUD_APP_ID=madai
MADCLOUD_APP_SECRET=<set-per-app-secret-on-server-only>
MADCLOUD_CALLBACK_URL=https://madaiapi.madprospects.com/api/madcloud/ai-results
MADCLOUD_AI_ROUTE=/ai
MADCLOUD_REQUIRE_SUPER_ADMIN=true
MADCLOUD_PUBLIC_SUBMIT_PATH=/api/madcloud/requests
MADCLOUD_PUBLIC_CALLBACK_PATH=/api/madcloud/ai-results
